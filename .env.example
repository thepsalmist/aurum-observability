# Postgres
POSTGRES_DB=mt5fx
POSTGRES_USER=mt5fx
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql+psycopg://mt5fx:change-me@postgres:5432/mt5fx

# SeaweedFS S3-compatible object storage
SEAWEEDFS_S3_ACCESS_KEY=mt5fx-publisher
SEAWEEDFS_S3_SECRET_KEY=change-me
SEAWEEDFS_BUCKET=mt5-backtests
SEAWEEDFS_S3_ENDPOINT_URL=http://seaweedfs:8333
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_S3_REGION=us-east-1

# Grafana local development
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_PORT=3000

# Artifact gateway
ARTIFACT_GATEWAY_BASE_URL=http://localhost:8000/artifacts
ARTIFACT_GATEWAY_AUTH_TOKEN=change-me
ARTIFACT_GATEWAY_AUTH_REQUIRED=true
